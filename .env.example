# Server
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO

# Workspace (must resolve outside the repo)
WORKSPACE_DIR=/tmp/portaible-workspace

# Database — defaults to sqlite+aiosqlite under WORKSPACE_DIR if unset
DATABASE_URL=

# Ollama / DSPy LM for SourceAnalyzer + destination + decisions
OLLAMA_URL=http://localhost:11434
OLLAMA_API_KEY=ollama
SOURCE_ANALYZER_MODEL=gemma3:27b
DESTINATION_SUGGEST_MODEL=
DESIGN_DECISIONS_MODEL=
LLM_TIMEOUT=180
LLM_MAX_RETRIES=3
NUM_CTX=32768

# Source extraction
GITHUB_CLONE_DEPTH=1
ANALYZER_MAX_FILES=200
ANALYZER_MAX_FILE_BYTES=20000

# AI Pipeline (local-chat-agent)
AI_PIPELINE_URL=http://localhost:8000
AI_PIPELINE_TIMEOUT=600
AI_PIPELINE_POLL_INTERVAL_SECONDS=2

# Prompt bank
PROMPT_BANK_DIR=./prompt-bank

# CORS for Nuxt dev server (single origin or comma-separated list; Nuxt may pick
# 3001/3002 if 3000 is taken — set this to whatever Nuxt prints)
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002
